# =============================================================================
# VietTune — E2E multi-role (Real API) example
# =============================================================================
# IMPORTANT: Playwright chỉ load `.env` và `.env.local` (see `playwright.config.ts`).
# File này chỉ là ví dụ. Hãy copy các dòng cần thiết sang `.env.local`.
# Không commit `.env.local`.
# =============================================================================

# --- Playwright base URL ---
# Local: để trống (Playwright sẽ dùng http://localhost:3000 và tự chạy `npm run dev` nếu cần)
# Staging: set origin để Playwright không bật Vite webServer (ví dụ https://staging.viettune.vn)
# PW_BASE_URL=https://staging.viettune.vn

# --- Playwright profile ---
# PW_ENV=production

# --- Role credentials (auth.setup.ts) ---
# Các tài khoản phải tồn tại trên backend bạn đang trỏ tới (Real DB).
E2E_CONTRIBUTOR_EMAIL=contributor1@gmail.com
E2E_CONTRIBUTOR_PASSWORD=1

E2E_EXPERT_EMAIL=expert1@gmail.com
E2E_EXPERT_PASSWORD=1

E2E_RESEARCHER_EMAIL=researcher1@gmail.com
E2E_RESEARCHER_PASSWORD=1

E2E_ADMIN_EMAIL=admin@gmail.com
E2E_ADMIN_PASSWORD=1

# --- Optional: skip các test nặng/ghi dữ liệu ---
# E2E_SKIP_HEAVY=1

# --- Vite / app: API ---
# Mặc định code dùng "/api" (relative) và dựa vào Vite proxy khi chạy local.
# Nếu muốn trỏ trực tiếp backend mà không cần proxy, set full URL:
# VITE_API_BASE_URL=https://localhost:7001/api

# --- Vite / app: Supabase (cần cho các flow upload thật) ---
# Nếu bạn chỉ chạy guest/admin/researcher UI thì có thể không cần.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_BUCKET=VietTuneArchive

